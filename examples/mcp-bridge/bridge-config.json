{
  "port": 3100,
  "servers": {
    "acme-tools": {
      "command": "node",
      "args": ["./dist/server.js"],
      "cwd": "/path/to/acme-tools"
    },
    "data-tools": {
      "command": "python",
      "args": ["-m", "data_tools"],
      "env": {
        "DATA_DIR": "/path/to/data"
      }
    }
  }
}
